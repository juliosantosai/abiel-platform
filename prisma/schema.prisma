datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  // Borra la línea 'output' por ahora, dejaremos que Prisma use su lugar estándar
}

model Empresa {
  id                 String   @id @default(uuid())
  nombre             String
  email              String?
  telefono           String?
  whatsappInstanceId String?
  estado             String
  plan               String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Usuario {
  id         String   @id @default(uuid())
  empresaId  String
  nombre     String
  email      String
  rol        String
  estado     String   @default("PENDIENTE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([empresaId])
  @@index([email])
}
