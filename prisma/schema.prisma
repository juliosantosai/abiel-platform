datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  // Borra la línea 'output' por ahora, dejaremos que Prisma use su lugar estándar
}

model Empresa {
  id                 String   @id @default(uuid())
  nombre             String
  email              String?
  telefono           String?
  whatsappInstanceId String?
  estado             String
  plan               String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Usuario {
  id         String   @id @default(uuid())
  empresaId  String
  nombre     String
  email      String
  rol        String
  estado     String   @default("PENDIENTE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([empresaId])
  @@index([email])
}

model ConversationSession {
  id                      String    @id @default(uuid())
  empresaId               String
  clienteId               String
  estado                  String    @default("BOT_ACTIVE")
  ultimaIntervencionHumana DateTime?
  creadoEn                DateTime  @default(now())
  actualizadoEn           DateTime  @updatedAt

  @@index([empresaId])
  @@index([clienteId])
  @@index([empresaId, clienteId])
}

model MessageBuffer {
  id             String    @id @default(uuid())
  empresaId      String
  conversationId String
  mensajes       Json      @default("[]")
  estado         String    @default("COLLECTING")
  ventanaMs      Int       @default(3000)
  maxMensajes    Int       @default(10)
  expiraEn       DateTime
  creadoEn       DateTime  @default(now())
  actualizadoEn  DateTime  @updatedAt

  @@index([empresaId])
  @@index([conversationId])
  @@index([estado, expiraEn])
}

model ConversationFlow {
  id             String   @id @default(uuid())
  empresaId      String
  conversationId String
  etapa          String
  etapaAnterior  String?
  contexto       Json     @default("{}")
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  @@index([empresaId])
  @@index([conversationId])
}

model OutboundMessage {
  id             String    @id @default(uuid())
  empresaId      String
  conversationId String?
  clienteId      String
  contenido      String
  tipo           String    @default("TEXT")
  estado         String    @default("PENDING")
  intentos       Int       @default(0)
  creadoEn       DateTime  @default(now())
  enviadoEn      DateTime?

  @@index([empresaId])
  @@index([estado])
}
