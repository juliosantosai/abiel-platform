{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "types/**/*", "app.js", "prisma.config.ts"],
  "exclude": ["node_modules", "dist", "coverage", "**/*.js"]
}
