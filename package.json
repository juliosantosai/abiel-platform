{
  "name": "abiel-core",
  "version": "1.0.0",
  "description": "Abiel Core SaaS",
  "main": "app.ts",
  "scripts": {
    "start": "node -r ts-node/register/transpile-only app.ts",
    "start:api:mock": "node -r ts-node/register/transpile-only src/modules/api/infrastructure/runApiMock.ts",
    "build": "npm run typecheck:build",
    "test": "npx prisma generate && jest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:build": "tsc -p tsconfig.build.json",
    "arch:check": "node tools/architecture/check-architecture.ts",
    "arch:check:strict": "node tools/architecture/check-architecture.ts --strict",
    "arch:inventory:wrappers": "node tools/architecture/check-architecture.ts --write-inventory",
    "arch:inventory:wrapper-ts": "node tools/architecture/audit-wrapper-ts.ts"
  },
  "devDependencies": {
    "@types/node": "^20.5.12",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "uuid": "^11.1.1",
    "js-yaml": "^4.1.0"
  }
}
