# Abiel Core — Environment Variables

# Required: JWT secret key for token signing and verification
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here

# Optional: Node environment (development, test, production)
# Default: development
NODE_ENV=development

# Optional: Database URL (Prisma will use prisma/.env if not set here)
# DATABASE_URL=postgresql://user:password@localhost:5432/tienda

# Optional: Log level (debug, info, warn, error)
# Default: info
LOG_LEVEL=info
